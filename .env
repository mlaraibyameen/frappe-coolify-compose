# =============================================================================
# Frappe / HRMS on Coolify — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# In Coolify, set these in the Environment Variables panel.
#
# FIRST-TIME DEPLOYMENT ORDER:
#   1. Fill in all values below and deploy.
#   2. Wait for `db` to be healthy, then `configurator` to exit 0.
#   3. Wait for `create-site` to finish (check its logs).
#   4. Set CONFIGURE=0 and CREATE_SITE=0, then redeploy.
#      (Leave ENABLE_DB=1 — it must keep running.)
#
# If services show Redis errors (127.0.0.1:6379 / 127.0.0.1:11311),
# it means `configurator` never ran. Set CONFIGURE=1 and redeploy.
# =============================================================================

# -----------------------------------------------------------------------------
# Coolify Proxy (auto-generated by Coolify — do not set manually)
# -----------------------------------------------------------------------------
# Coolify generates these when you assign a domain to this service.
# The _8080 suffix tells Coolify to route traffic to Nginx on port 8080.
# SERVICE_FQDN_FRONTEND_8080=yourdomain.example.com
# SERVICE_URL_FRONTEND=https://yourdomain.example.com

# -----------------------------------------------------------------------------
# Docker Image
# -----------------------------------------------------------------------------

# The Frappe app image to use.
# ERPNext: ghcr.io/frappe/erpnext
# HRMS:    ghcr.io/frappe/hrms
IMAGE_NAME=ghcr.io/frappe/hrms

# Image tag / Frappe version. Use a specific tag for production.
VERSION=v16.4.3

# Docker pull policy. Use "always" to always pull latest, or "if-not-present"
# to skip if already cached.
PULL_POLICY=always

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------

# The site name — MUST exactly match the domain Coolify proxies to this service.
# This is used to create the site directory and route incoming requests.
# Example: erp.mycompany.com
SITE_NAME=erp.alliedtechglobal.com

# Administrator password for the Frappe site.
ADMIN_PASSWORD=aDm1n@12360

# Apps to install when creating the site. Leave blank for Frappe only.
# Example: --install-app erpnext
# Example: --install-app erpnext --install-app hrms
INSTALL_APP_ARGS=--install-app hrms

# Header used to determine site name from the incoming request.
# $host uses the HTTP Host header — correct for most Coolify setups.
FRAPPE_SITE_NAME_HEADER=$host

# Set to 1 to regenerate apps.txt from installed apps on startup.
REGENERATE_APPS_TXT=0

# -----------------------------------------------------------------------------
# Database (MariaDB)
# -----------------------------------------------------------------------------

# Root password for MariaDB. Used by the db service and site creation.
DB_ROOT_PASSWORD=aDm1n@@1122336600

# Database host. Use "db" to use the bundled MariaDB service.
# Set to your external DB hostname if ENABLE_DB=0.
DB_HOST=db

# Database port. Default: 3306
DB_PORT=3306

# -----------------------------------------------------------------------------
# Volumes (sites)
# -----------------------------------------------------------------------------
# The `sites` volume stores all Frappe site data (configs, uploads, etc.)
# and is shared across all services. It must persist across restarts.
#
# For a bind mount to a host path (recommended for single-server setups):
#   SITE_VOLUME_TYPE=none
#   SITE_VOLUME_OPTS=bind
#   SITE_VOLUME_DEV=/absolute/path/on/host
#
# ALL THREE must be set — leaving any blank will cause volume errors.

SITE_VOLUME_TYPE=none
SITE_VOLUME_OPTS=bind
SITE_VOLUME_DEV=/data/frappe/sites

# -----------------------------------------------------------------------------
# One-shot service replicas (Coolify toggle pattern)
# -----------------------------------------------------------------------------
# These control services that should run ONCE and stop.
# Set to 1 to run, then set back to 0 after the service completes.
#
# WARNING: If CONFIGURE=0 and no common_site_config.json exists, all workers
# and the websocket will fail with Redis connection errors (127.0.0.1).
# Always run CONFIGURE=1 on first deploy before starting other services.
#
# Deployment sequence:
#   Step 1 — ENABLE_DB=1, CONFIGURE=1, CREATE_SITE=1  → first deploy
#   Step 2 — ENABLE_DB=1, CONFIGURE=0, CREATE_SITE=0  → after site is created
#
# For updates (new image version):
#   Step 1 — MIGRATE=1  → runs bench migrate
#   Step 2 — MIGRATE=0  → normal operation

# Keep at 1 permanently. Set to 0 only if using an external database.
ENABLE_DB=1

# Writes Redis and DB connection details into common_site_config.json.
# MUST be 1 on first deploy. Set back to 0 after it exits successfully.
CONFIGURE=1

# Creates the Frappe site (bench new-site). Run once after CONFIGURE completes.
# Set back to 0 after the site is created.
CREATE_SITE=1

# Runs bench migrate. Set to 1 after pulling a new image version, then back to 0.
MIGRATE=0
