# =============================================================================
# Frappe / HRMS on Coolify — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# In Coolify, set these in the Environment Variables panel.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Image
# -----------------------------------------------------------------------------

# The Frappe app image to use.
# ERPNext: ghcr.io/frappe/erpnext
# HRMS:    ghcr.io/frappe/hrms
IMAGE_NAME=ghcr.io/frappe/hrms

# Image tag / Frappe version. Use a specific tag for production.
VERSION=version-15

# Docker pull policy. Use "always" to always pull latest, or "if-not-present"
# to skip if already cached.
PULL_POLICY=always

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------

# The site name — must match the domain Coolify proxies to this service.
# Example: erp.mycompany.com
SITE_NAME=mysite.example.com

# Administrator password for the Frappe site.
ADMIN_PASSWORD=changeme

# Apps to install when creating the site. Leave blank for Frappe only.
# Example: --install-app erpnext
# Example: --install-app erpnext --install-app hrms
INSTALL_APP_ARGS=--install-app hrms

# Header used to determine site name from the incoming request.
# Default ($$host) uses the Host header — correct for most setups.
FRAPPE_SITE_NAME_HEADER=$$host

# Set to 1 to regenerate apps.txt from installed apps on startup.
REGENERATE_APPS_TXT=0

# -----------------------------------------------------------------------------
# Database (MariaDB)
# -----------------------------------------------------------------------------

# Root password for MariaDB. Used by the db service and site creation.
DB_ROOT_PASSWORD=supersecretpassword

# Database host. Use "db" to use the bundled MariaDB service.
# Set to your external DB hostname if ENABLE_DB=0.
DB_HOST=db

# Database port. Default: 3306
DB_PORT=3306

# -----------------------------------------------------------------------------
# Volumes (sites)
# -----------------------------------------------------------------------------
# The `sites` volume stores all Frappe site data. Configure driver options here.
# For local storage, use:
#   SITE_VOLUME_TYPE=none
#   SITE_VOLUME_OPTS=bind
#   SITE_VOLUME_DEV=/path/on/host/sites

SITE_VOLUME_TYPE=none
SITE_VOLUME_OPTS=bind
SITE_VOLUME_DEV=/data/frappe/sites

# -----------------------------------------------------------------------------
# One-shot service replicas (Coolify toggle pattern)
# -----------------------------------------------------------------------------
# Set to 1 to run the service once, then set back to 0 after it completes.
# Coolify lets you change these without editing the compose file.

# Start the bundled MariaDB database. Set to 0 if using an external DB.
ENABLE_DB=1

# Run the configurator (writes common_site_config.json). Run once on first deploy.
CONFIGURE=1

# Create a new Frappe site. Run once after configurator completes.
CREATE_SITE=1

# Run bench migrate (for updates). Set to 1 after pulling a new image version.
MIGRATE=0
